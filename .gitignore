# ---------- Dependencies ----------
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ---------- Environment / secrets ----------
.env
.env.*
!.env.example

# ---------- Build output ----------
dist/
build/
client/dist/
*.tsbuildinfo

# ---------- yt-dlp binary (auto-downloaded on first run) ----------
server/bin/
bin/yt-dlp
bin/yt-dlp.exe

# ---------- Temp downloads (keep the folder, ignore its contents) ----------
server/downloads/*
!server/downloads/.gitkeep
downloads/*
!downloads/.gitkeep

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ---------- Caches ----------
.cache/
.vite/
.eslintcache
coverage/

# ---------- Editor / IDE ----------
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ---------- OS files ----------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
